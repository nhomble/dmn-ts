{
  "name": "tom-rools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "tom-rools": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test 'dist/**/*.test.js'",
    "transpile": "node --enable-source-maps dist/cli.js",
    "harness": "node --enable-source-maps dist/harness.js",
    "batch": "node --enable-source-maps dist/batch.js",
    "tck:1.1.cl2": "npm run build && node --enable-source-maps dist/batch.js ../oss/jdmn/dmn-test-cases/standard/tck/1.1/cl2",
    "tck:1.1.cl3": "npm run build && node --enable-source-maps dist/batch.js ../oss/jdmn/dmn-test-cases/standard/tck/1.1/cl3 -o out/cl3.1.1",
    "tck:all": "npm run build && node --enable-source-maps dist/batch.js ../oss/jdmn/dmn-test-cases/standard/tck -o out/all"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
